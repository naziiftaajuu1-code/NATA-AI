<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1D"> <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#111827"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/app_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NATA AI"
            android:textColor="#38BDF8"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1E293B"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:backgroundTint="#1E293B">
            
            <TextView
                android:id="@+id/txt_coin_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🪙 125 Coin"
                android:textColor="#FBBF24"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/quick_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_bar"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:weightSum="2">

        <Button
            android:id="@+id/btn_new_chat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginRight="5dp"
            android:text="➕ New Chat"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0EA5E9"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_watch_ad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="5dp"
            android:text="📺 Ads (Get Free Coin)"
            android:textColor="#FFFFFF"
            android:backgroundTint="#10B981"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/model_selector_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/quick_actions"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 Model:"
            android:textColor="#9CA3AF"
            android:textSize="14sp"
            android:layout_marginRight="10dp" />

        <Spinner
            android:id="@+id/spinner_models"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="#1F2937"
            android:entries="@array/ai_models_array" /> </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/model_selector_container"
        android:layout_above="@id/input_container"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📜 Question History"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="5dp"/>
            
        <HorizontalScrollView
            android:id="@+id/history_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="15dp">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Uumi Suuraa..."
                    android:textColor="#9CA3AF"
                    android:background="#1F2937"
                    android:padding="8dp"
                    android:layout_marginRight="8dp"
                    android:textSize="13sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝 Seenaa Oromoo..."
                    android:textColor="#9CA3AF"
                    android:background="#1F2937"
                    android:padding="8dp"
                    android:layout_marginRight="8dp"
                    android:textSize="13sp"/>
            </LinearLayout>
        </HorizontalScrollView>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#111827"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/img_ai_preview"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginBottom="10dp"
                    android:contentDescription="AI Generated Image Display" />

                <TextView
                    android:id="@+id/tv_ai_response"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NATA AI: Akkam jirtu? Ani qophiidha, na gaafadhu!"
                    android:textColor="#E5E7EB"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/input_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#111827"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_user_query"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Asirratti barreessi..."
            android:textColor="#FFFFFF"
            android:textColorHint="#4B5563"
            android:background="#1F2937"
            android:padding="12dp"
            android:textSize="14sp"
            android:maxLines="3" />

        <ImageButton
            android:id="@+id/btn_submit_query"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginLeft="10dp"
            android:backgroundTint="#38BDF8"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="Send Query Button" />
    </LinearLayout>

</RelativeLayout>
